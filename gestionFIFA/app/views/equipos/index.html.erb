<div class="action-row">
  <div class="action-row-left">
    <%= link_to "← #{@torneo.nombre}", torneo_path(@torneo), class: "back-link" %>
    <h2>Equipos</h2>
  </div>
  <div style="display: flex; gap: 12px; align-items: center;">
    <button class="btn-green" onclick="abrirModalCrear()">+ Añadir equipo</button>
    <input type="text" id="buscador-equipos" class="search-input" placeholder="Buscar equipo..." oninput="filtrarEquipos()">
  </div>
</div>

<% if @equipos.any? %>
  <div class="equipos-list">
    <% @equipos.each do |equipo| %>
      <div class="list-item">
        <div class="team-meta">
          <div class="item-details">
            <h3><%= equipo.nombre %></h3>
            <p>Grupo <%= equipo.grupo.nombre %></p>
          </div>
        </div>
        <div class="list-item-right">
          <div class="team-stats-row">
            <span class="stat-pill"><%= equipo.puntos %> pts</span>
            <span class="stat-pill"><%= equipo.goles_favor %> GF</span>
            <span class="stat-pill stat-dg <%= equipo.diferencia_de_goles >= 0 ? 'positive' : 'negative' %>">
              <%= equipo.diferencia_de_goles >= 0 ? '+' : '' %><%= equipo.diferencia_de_goles %> DG
            </span>
          </div>
          <button class="btn-edit"
              onclick="abrirModal(<%= equipo.id %>, '<%= j equipo.nombre %>', '<%= equipo.grupo_id %>')">
            Editar
          </button>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <div class="empty-state-icon"></div>
    <p class="empty-state-title">No hay equipos registrados</p>
    <p class="empty-state-desc">Los equipos aparecerán aquí una vez que se registren en el torneo</p>
  </div>
<% end %>

<!-- ========== MODAL DE EDICIÓN ========== -->
<div class="modal-overlay" id="modal-editar" onclick="cerrarModalSiAfuera(event)">
  <div class="modal-box">
    <div class="modal-header">
      <h3 id="modal-titulo">Editar equipo</h3>
      <button class="modal-close" onclick="cerrarModal()" aria-label="Cerrar">&times;</button>
    </div>

    <%= form_with url: torneo_equipos_path(@torneo), method: :patch, scope: :equipo, id: "form-editar-equipo", local: true, authenticity_token: true, data: { turbo: false } do |f| %>
      <div class="form-group">
        <label class="form-label">Nombre del país</label>
        <%= f.text_field :nombre, id: "campo-nombre", class: "form-input", placeholder: "Nombre del equipo" %>
      </div>

      <div class="form-group">
        <label class="form-label">Grupo</label>
        <%= f.select :grupo_id, @torneo.grupos.order(:nombre).map { |g| ["Grupo #{g.nombre}", g.id] },
              {}, { id: "campo-grupo", class: "form-input", onchange: "actualizarSwap()" } %>
      </div>

      <div class="form-group" id="swap-section" style="display:none;">
        <label class="form-label" style="color: var(--red);">Grupo lleno: intercambiar con:</label>
        <select id="campo-swap" name="swap_id" class="form-input">
          <option value="">Seleccione un equipo</option>
        </select>
      </div>

      <div class="form-info-box">
        Las estadísticas del equipo se calculan automáticamente desde los resultados de los partidos.
      </div>

      <div class="modal-actions">
        <button type="button" id="btn-borrar-equipo" class="btn-red" style="margin-right: auto;" onclick="abrirConfirmacionEquipo()">
          Borrar
        </button>
        <button type="button" class="btn-stroke" onclick="cerrarModal()">Cancelar</button>
        <%= f.submit "Guardar cambios", class: "btn-green" %>
      </div>
    <% end %>
  </div>
</div>

<!-- ========== MODAL CONFIRMAR BORRAR EQUIPO ========== -->
<div class="modal-overlay modal-confirm-overlay" id="modal-confirmar-equipo" onclick="cerrarConfirmacionEquipoSiAfuera(event)">
  <div class="modal-box modal-box--narrow">
    <div class="modal-header">
      <h3 class="modal-title">Confirmar eliminación</h3>
      <button class="modal-close" onclick="cerrarConfirmacionEquipo()" aria-label="Cerrar">&times;</button>
    </div>

    <div class="confirm-content">

      <p class="confirm-title">
        ¿Eliminar <strong id="nombre-equipo-borrar">este equipo</strong>?
      </p>

      <p class="confirm-desc">
        Esta acción eliminará el equipo del torneo.
      </p>
    </div>

    <div class="modal-actions modal-actions-confirm">
      <button type="button" class="btn-stroke" onclick="cerrarConfirmacionEquipo()">Cancelar</button>
      <button type="button" class="btn-red" onclick="confirmarEliminarEquipo()">Sí, eliminar</button>
    </div>
  </div>
</div>

<!-- ========== MODAL DE CREACIÓN ========== -->
<div class="modal-overlay" id="modal-crear" onclick="cerrarModalCrearSiAfuera(event)">
  <div class="modal-box">
    <div class="modal-header">
      <h3>Añadir equipo</h3>
      <button class="modal-close" onclick="cerrarModalCrear()" aria-label="Cerrar">&times;</button>
    </div>

    <%= form_with url: torneo_equipos_path(@torneo), method: :post, scope: :equipo, id: "form-crear-equipo", local: true, authenticity_token: true, data: { turbo: false } do |f| %>

      <% if @nombres_existentes.any? %>
        <div class="crear-tabs">
          <button type="button" class="crear-tab active" onclick="cambiarTab('existente')">Seleccionar existente</button>
          <button type="button" class="crear-tab" onclick="cambiarTab('nuevo')">Escribir nuevo</button>
        </div>

        <div id="tab-existente">
          <div class="form-group">
            <input type="text" id="buscador-existentes" class="form-input" placeholder="Buscar país…" oninput="filtrarExistentes()">
          </div>
          <div class="equipos-existentes-lista" id="lista-existentes">
            <% @nombres_existentes.each do |nombre| %>
              <button type="button" class="equipo-existente-btn" onclick="seleccionarExistente('<%= j nombre %>')">
                <%= nombre %>
              </button>
            <% end %>
          </div>
        </div>

        <div id="tab-nuevo" style="display:none;">
          <div class="form-group">
            <label class="form-label">Nombre del país</label>
            <input type="text" id="crear-campo-nombre" class="form-input" placeholder="Nombre del equipo"
                   oninput="document.getElementById('crear-nombre-hidden').value = this.value; document.getElementById('btn-añadir-equipo').disabled = this.value.trim() === ''">
          </div>
        </div>

        <input type="hidden" id="crear-nombre-hidden" name="equipo[nombre]">
      <% else %>
        <div class="form-group">
          <label class="form-label">Nombre del país</label>
          <%= f.text_field :nombre, id: "crear-campo-nombre", class: "form-input", placeholder: "Nombre del equipo", required: true %>
        </div>
      <% end %>

      <div class="form-group">
        <label class="form-label">Grupo</label>
        <%= f.select :grupo_id, @torneo.grupos.order(:nombre).map { |g| ["Grupo #{g.nombre}", g.id] },
              { prompt: "Selecciona un grupo" }, { id: "crear-campo-grupo", class: "form-input", required: true, onchange: "actualizarReemplazo()" } %>
      </div>

      <div class="form-group" id="reemplazo-section" style="display:none;">
        <label class="form-label" style="color: var(--red);">Grupo lleno - reemplazar y eliminar:</label>
        <select id="campo-reemplazo" name="reemplazar_id" class="form-input">
          <option value="">- Selecciona un equipo -</option>
        </select>
      </div>

      <div id="equipo-seleccionado-aviso" class="form-info-box" style="display:none;">
        Equipo seleccionado: <strong id="equipo-seleccionado-nombre"></strong>
      </div>

      <div class="modal-actions">
        <button type="button" class="btn-stroke" onclick="cerrarModalCrear()">Cancelar</button>
        <%= f.submit "Añadir equipo", id: "btn-añadir-equipo", class: "btn-green", disabled: true %>
      </div>
    <% end %>
  </div>
</div>

<script>
  const BASE_URL = "<%= torneo_equipos_path(@torneo) %>";

  const GRUPOS_DATA = <%= @torneo.grupos.includes(:equipos).order(:nombre).map { |g|
    { id: g.id, nombre: g.nombre, lleno: g.equipos.count >= 4,
      equipos: g.equipos.map { |e| { id: e.id, nombre: e.nombre } } }
  }.to_json.html_safe %>;

  let equipoActualId = null;
  let equipoActualNombre = null;
  let grupoActualId  = null;

  function abrirModal(id, nombre, grupoId) {
    equipoActualId = id;
    grupoActualId  = parseInt(grupoId);
    equipoActualNombre = nombre;

    document.getElementById("modal-titulo").textContent = "Editar: " + nombre;
    document.getElementById("form-editar-equipo").action = BASE_URL + "/" + id;
    document.getElementById("campo-nombre").value = nombre;
    document.getElementById("campo-grupo").value = grupoId;
    document.getElementById("campo-swap").value = "";
    document.getElementById("swap-section").style.display = "none";

    const overlay = document.getElementById("modal-editar");
    overlay.style.display = "flex";
    requestAnimationFrame(() => overlay.classList.add("visible"));
  }

  function actualizarSwap() {
    const nuevoGrupoId = parseInt(document.getElementById("campo-grupo").value);
    const swapSection  = document.getElementById("swap-section");
    const swapSelect   = document.getElementById("campo-swap");

    if (nuevoGrupoId === grupoActualId) {
      swapSection.style.display = "none";
      swapSelect.value = "";
      return;
    }

    const grupoDestino = GRUPOS_DATA.find(g => g.id === nuevoGrupoId);
    if (grupoDestino && grupoDestino.lleno) {
      swapSelect.innerHTML = '<option value="">Selecciona un equipo</option>';
      grupoDestino.equipos
        .filter(e => e.id !== equipoActualId)
        .forEach(e => {
          const opt = document.createElement("option");
          opt.value = e.id;
          opt.textContent = e.nombre;
          swapSelect.appendChild(opt);
        });
      swapSection.style.display = "";
    } else {
      swapSection.style.display = "none";
      swapSelect.value = "";
    }
  }

  function cerrarModal() {
    const overlay = document.getElementById("modal-editar");
    overlay.classList.remove("visible");
    setTimeout(() => { overlay.style.display = "none"; }, 200);
  }

  function cerrarModalSiAfuera(event) {
    if (event.target === document.getElementById("modal-editar")) cerrarModal();
  }

  function abrirConfirmacionEquipo() {
  if (!equipoActualId) return;

  document.getElementById("nombre-equipo-borrar").textContent = equipoActualNombre || "este equipo";

  const modal = document.getElementById("modal-confirmar-equipo");
  modal.style.display = "flex";

  requestAnimationFrame(() => {
    modal.classList.add("visible");
  });
}

function cerrarConfirmacionEquipo() {
  const modal = document.getElementById("modal-confirmar-equipo");
  modal.classList.remove("visible");

  setTimeout(() => {
    modal.style.display = "none";
  }, 200);
}

function cerrarConfirmacionEquipoSiAfuera(event) {
  if (event.target === document.getElementById("modal-confirmar-equipo")) {
    cerrarConfirmacionEquipo();
  }
}

function confirmarEliminarEquipo() {
  if (!equipoActualId) return;

  const token = document.querySelector('meta[name="csrf-token"]').content;

  const form = document.createElement("form");
  form.method = "post";
  form.action = BASE_URL + "/" + equipoActualId;

  const metodo = document.createElement("input");
  metodo.type = "hidden";
  metodo.name = "_method";
  metodo.value = "delete";

  const csrf = document.createElement("input");
  csrf.type = "hidden";
  csrf.name = "authenticity_token";
  csrf.value = token;

  form.appendChild(metodo);
  form.appendChild(csrf);
  document.body.appendChild(form);
  form.submit();
}

  function abrirModalCrear() {
    document.getElementById("form-crear-equipo").reset();
    document.getElementById("reemplazo-section").style.display = "none";
    document.getElementById("campo-reemplazo").value = "";

    const hidden = document.getElementById("crear-nombre-hidden");
    if (hidden) hidden.value = "";

    const aviso = document.getElementById("equipo-seleccionado-aviso");
    if (aviso) aviso.style.display = "none";

    const btn = document.getElementById("btn-añadir-equipo");
    if (btn) btn.disabled = true;

    const buscador = document.getElementById("buscador-existentes");
    if (buscador) { buscador.value = ""; filtrarExistentes(); }

    cambiarTab("existente");

    const overlay = document.getElementById("modal-crear");
    overlay.style.display = "flex";
    requestAnimationFrame(() => overlay.classList.add("visible"));
  }

  function cambiarTab(tab) {
    const tabExistente = document.getElementById("tab-existente");
    const tabNuevo     = document.getElementById("tab-nuevo");
    const tabs         = document.querySelectorAll(".crear-tab");
    const hidden       = document.getElementById("crear-nombre-hidden");
    const btn          = document.getElementById("btn-añadir-equipo");
    const aviso        = document.getElementById("equipo-seleccionado-aviso");

    if (!tabExistente || !tabNuevo) return;

    if (tab === "existente") {
      tabExistente.style.display = "";
      tabNuevo.style.display = "none";
      tabs[0].classList.add("active");
      tabs[1].classList.remove("active");
      if (hidden) hidden.value = "";
      if (aviso) aviso.style.display = "none";
      if (btn) btn.disabled = true;
    } else {
      tabExistente.style.display = "none";
      tabNuevo.style.display = "";
      tabs[0].classList.remove("active");
      tabs[1].classList.add("active");
      if (hidden) hidden.value = "";
      if (aviso) aviso.style.display = "none";
      if (btn) btn.disabled = false;
    }
  }

  function seleccionarExistente(nombre) {
    const hidden = document.getElementById("crear-nombre-hidden");
    if (hidden) hidden.value = nombre;

    document.querySelectorAll(".equipo-existente-btn").forEach(b => b.classList.remove("selected"));
    event.currentTarget.classList.add("selected");

    const aviso = document.getElementById("equipo-seleccionado-aviso");
    const nombreEl = document.getElementById("equipo-seleccionado-nombre");
    if (aviso) aviso.style.display = "";
    if (nombreEl) nombreEl.textContent = nombre;

    const btn = document.getElementById("btn-añadir-equipo");
    if (btn) btn.disabled = false;
  }

  function filtrarExistentes() {
    const texto = document.getElementById("buscador-existentes").value.toLowerCase();
    document.querySelectorAll(".equipo-existente-btn").forEach(btn => {
      btn.style.display = btn.textContent.toLowerCase().includes(texto) ? "" : "none";
    });
  }

  function actualizarReemplazo() {
    const grupoId      = parseInt(document.getElementById("crear-campo-grupo").value);
    const section      = document.getElementById("reemplazo-section");
    const select       = document.getElementById("campo-reemplazo");
    const grupoDestino = GRUPOS_DATA.find(g => g.id === grupoId);

    if (grupoDestino && grupoDestino.lleno) {
      select.innerHTML = '<option value="">- Selecciona un equipo -</option>';
      grupoDestino.equipos.forEach(e => {
        const opt = document.createElement("option");
        opt.value = e.id;
        opt.textContent = e.nombre;
        select.appendChild(opt);
      });
      section.style.display = "";
    } else {
      section.style.display = "none";
      select.value = "";
    }
  }

  function cerrarModalCrear() {
    const overlay = document.getElementById("modal-crear");
    overlay.classList.remove("visible");
    setTimeout(() => { overlay.style.display = "none"; }, 200);
  }

  function cerrarModalCrearSiAfuera(event) {
    if (event.target === document.getElementById("modal-crear")) cerrarModalCrear();
  }

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape") { cerrarModal(); cerrarModalCrear(); }
  });

  function filtrarEquipos() {
    const texto = document.getElementById("buscador-equipos").value.toLowerCase();
    document.querySelectorAll(".equipos-list .list-item").forEach(function(fila) {
      fila.style.display = fila.querySelector("h3").textContent.toLowerCase().includes(texto) ? "" : "none";
    });
  }
</script>
