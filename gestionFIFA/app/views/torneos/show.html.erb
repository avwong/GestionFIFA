<div class="action-row">
  <div class="action-row-left">
    <%= link_to "← Torneos", torneos_path, class: "back-link" %>
    <h2><%= @torneo.nombre %></h2>
    <span class="tipo-badge tipo-badge--<%= @torneo.tipo %>">
      <%= @torneo.tipo == "mundial" ? "Mundial" : "Bracket" %>
    </span>
  </div>
  <%= link_to "Equipos", torneo_equipos_path(@torneo), class: "btn-stroke btn-sm" %>
</div>

<!-- Sub-navegación -->
<div class="sub-nav">
  <%= link_to "Fase de Grupos", torneo_path(@torneo, seccion: "fase_grupos"),
        class: "sub-nav-tab #{@seccion == 'fase_grupos' ? 'active' : ''}" %>
  <%= link_to "Clasificados", torneo_path(@torneo, seccion: "clasificados"),
        class: "sub-nav-tab #{@seccion == 'clasificados' ? 'active' : ''}" %>
  <%= link_to "Eliminación Directa", torneo_path(@torneo, seccion: "eliminacion"),
        class: "sub-nav-tab #{@seccion == 'eliminacion' ? 'active' : ''}" %>
  <%= link_to "Podio", torneo_path(@torneo, seccion: "podio"),
        class: "sub-nav-tab #{@seccion == 'podio' ? 'active' : ''}" %>
</div>

<% if @seccion == "podio" %>
  <!-- ========== PODIO ========== -->
  <% if @primero || @segundo || @tercero %>
    <div class="podium-wrapper">
      <h3 class="podium-title">Campeones de <%= @torneo.nombre %></h3>
      <div class="podium">
        <div class="podium-place podium-2nd">
          <div class="podium-name"><%= @segundo&.nombre || "—" %></div>
          <div class="podium-block">
            <span class="podium-medal">🥈</span>
            <span class="podium-rank">2</span>
          </div>
        </div>
        <div class="podium-place podium-1st">
          <div class="podium-trophy">🏆</div>
          <div class="podium-name"><%= @primero&.nombre || "—" %></div>
          <div class="podium-block">
            <span class="podium-medal">🥇</span>
            <span class="podium-rank">1</span>
          </div>
        </div>
        <div class="podium-place podium-3rd">
          <div class="podium-name"><%= @tercero&.nombre || "—" %></div>
          <div class="podium-block">
            <span class="podium-medal">🥉</span>
            <span class="podium-rank">3</span>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="coming-soon-wrapper">
      <div class="coming-soon-icon">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#C8C8C8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <h3 class="coming-soon-title">Podio no disponible aún</h3>
      <p class="coming-soon-desc">
        El podio se mostrará una vez hayan concluido los partidos.
      </p>
    </div>
  <% end %>

<% elsif @seccion == "fase_grupos" %>
  <!-- ========== FASE DE GRUPOS ========== -->
  <div class="section-actions">

    <div class="section-actions-right">
      <%= button_to "Generar partidos de grupos",
            generar_partidos_grupos_torneo_path(@torneo),
            method: :post,
            class: "btn-green btn-sm",
            form: { data: { turbo: false } } %>
    </div>
  </div>

  <% if @grupos.any? %>
    <div class="groups-grid">
      <% @grupos.each do |grupo| %>
        <% partidos_grupo = grupo.partidos.select { |p| p.fase == "fase_grupos" } %>

        <div class="group-card">
          <div class="group-title group-title-flex">
            <span>Grupo <%= grupo.nombre %></span>

            <div class="group-title-actions">
              <% if partidos_grupo.any? %>
                <button class="btn-edit btn-mini" onclick="abrirModalGrupo(<%= grupo.id %>)">
                  Editar partidos
                </button>
              <% else %>
                <span class="group-status-small">Sin partidos</span>
              <% end %>
            </div>
          </div>

          <% if grupo.equipos.any? %>
            <table class="group-table">
              <thead>
                <tr>
                  <th class="col-team">Equipo</th>
                  <th class="col-stat">PJ</th>
                  <th class="col-stat">PG</th>
                  <th class="col-stat">PE</th>
                  <th class="col-stat">PP</th>
                  <th class="col-stat">GF</th>
                  <th class="col-stat">GC</th>
                  <th class="col-stat">DG</th>
                  <th class="col-stat col-pts">Pts</th>
                </tr>
              </thead>
              <tbody>
                <% grupo.tabla_posiciones.each_with_index do |equipo, idx| %>
                    <% tercer_clasificado = idx == 2 && @mejores_terceros_ids.include?(equipo.id) %>
                    <tr class="<%= (idx < 2 || tercer_clasificado) ? 'clasificado' : '' %>">
                    <td class="col-team"><%= equipo.nombre %></td>
                    <td class="col-stat"><%= equipo.partidos_jugados %></td>
                    <td class="col-stat"><%= equipo.partidos_ganados %></td>
                    <td class="col-stat"><%= equipo.partidos_empatados %></td>
                    <td class="col-stat"><%= equipo.partidos_perdidos %></td>
                    <td class="col-stat"><%= equipo.goles_favor %></td>
                    <td class="col-stat"><%= equipo.goles_contra %></td>
                    <td class="col-stat"><%= equipo.diferencia_de_goles %></td>
                    <td class="col-stat col-pts"><%= equipo.puntos %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% else %>
            <p class="group-empty">Sin equipos asignados</p>
          <% end %>
        </div>

        <% if partidos_grupo.any? %>
          <div class="modal-overlay" id="modal-grupo-<%= grupo.id %>" onclick="cerrarModalGrupoSiAfuera(event, <%= grupo.id %>)">
            <div class="modal-box modal-box--wide">
              <div class="modal-header">
                <h3>Partidos del Grupo <%= grupo.nombre %></h3>
                <button class="modal-close" onclick="cerrarModalGrupo(<%= grupo.id %>)" aria-label="Cerrar">&times;</button>
              </div>

              <%= form_with url: guardar_partidos_grupo_torneo_path(@torneo, grupo_id: grupo.id),
                    method: :patch,
                    local: true,
                    data: { turbo: false } do %>

                <div class="matches-editor">
                  <% partidos_grupo.each do |partido| %>
                    <div class="match-editor-row">
                      <label class="match-played-check">
                        <%= check_box_tag "partidos[#{partido.id}][jugado]", "1", partido.finalizado?,
                              id: "partido_#{partido.id}_jugado",
                              onchange: "toggleJugado(#{partido.id}, this)" %>
                        Jugado
                      </label>

                      <div class="match-team match-team-left">
                        <%= partido.equipo_local.nombre %>
                      </div>

                      <div class="match-score-inputs">
                        <%= number_field_tag "partidos[#{partido.id}][goles_local]",
                              partido.goles_local,
                              min: 0,
                              class: "score-input",
                              oninput: "marcarPartidoJugado(#{partido.id})" %>
                        <span>-</span>
                        <%= number_field_tag "partidos[#{partido.id}][goles_visitante]",
                              partido.goles_visitante,
                              min: 0,
                              class: "score-input",
                              oninput: "marcarPartidoJugado(#{partido.id})" %>
                      </div>

                      <div class="match-team match-team-right">
                        <%= partido.equipo_visitante.nombre %>
                      </div>
                    </div>
                  <% end %>
                </div>

                <div class="modal-actions">
                  <button type="button" class="btn-stroke" onclick="cerrarModalGrupo(<%= grupo.id %>)">Cancelar</button>
                  <%= submit_tag "Guardar resultados", class: "btn-green" %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <script>
      function abrirModalGrupo(id) {
        const modal = document.getElementById("modal-grupo-" + id);
        modal.style.display = "flex";

        requestAnimationFrame(() => {
          modal.classList.add("visible");
        });
      }

      function cerrarModalGrupo(id) {
        const modal = document.getElementById("modal-grupo-" + id);
        modal.classList.remove("visible");

        setTimeout(() => {
          modal.style.display = "none";
        }, 200);
      }

      function cerrarModalGrupoSiAfuera(event, id) {
        if (event.target === document.getElementById("modal-grupo-" + id)) {
          cerrarModalGrupo(id);
        }
      }

      function marcarPartidoJugado(id) {
        const check = document.getElementById("partido_" + id + "_jugado");
        const gl = document.querySelector(`[name="partidos[${id}][goles_local]"]`);
        const gv = document.querySelector(`[name="partidos[${id}][goles_visitante]"]`);

        if (check && (gl?.value !== "" || gv?.value !== "")) {
          check.checked = true;
        }
      }

      function toggleJugado(id, checkbox) {
        const gl = document.querySelector(`[name="partidos[${id}][goles_local]"]`);
        const gv = document.querySelector(`[name="partidos[${id}][goles_visitante]"]`);

        if (checkbox.checked) {
          if (gl && gl.value === "") gl.value = "0";
          if (gv && gv.value === "") gv.value = "0";
        } else {
          if (gl) gl.value = "";
          if (gv) gv.value = "";
        }
      }
    </script>
  <% else %>
    <div class="coming-soon-wrapper">
      <div class="coming-soon-icon">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#C8C8C8" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        </svg>
      </div>
      <h3 class="coming-soon-title">Sin grupos</h3>
      <p class="coming-soon-desc">
        <%= link_to "Agrega equipos", torneo_equipos_path(@torneo) %> para comenzar la fase de grupos.
      </p>
    </div>
  <% end %>

<% elsif @seccion == "clasificados" %>
  <!-- ========== CLASIFICADOS ========== -->
  <div class="clasificados-header-simple">
    <h3>Clasificados a eliminación directa</h3>
    <p>
      Se muestran los primeros y segundos de cada grupo, más los ocho mejores terceros.
    </p>
  </div>

  <% if @total_partidos_grupos.zero? %>
    <div class="coming-soon-wrapper">
      <div class="coming-soon-icon">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#C8C8C8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <h3 class="coming-soon-title">Sin partidos generados</h3>
      <p class="coming-soon-desc">
        Primero genera los partidos de fase de grupos para calcular los clasificados.
      </p>
      <%= link_to "Volver a Fase de Grupos", torneo_path(@torneo, seccion: "fase_grupos"), class: "btn-stroke" %>
    </div>
  <% else %>
    <% unless @fase_grupos_completa %>
      <div class="clasificados-aviso">
        Clasificación provisional: todavía hay partidos pendientes en la fase de grupos.
      </div>
    <% end %>

    <h3 class="clasificados-section-title">Lista de países clasificados a eliminatoria</h3>

    <div class="qualified-list">
      <% @clasificados_eliminatoria.each_with_index do |equipo, index| %>
        <% es_mejor_tercero = @mejores_terceros_ids.include?(equipo.id) %>

        <div class="qualified-item">
          <span class="qualified-number"><%= index + 1 %></span>

          <div class="qualified-main">
            <strong><%= equipo.nombre %></strong>
            <small>
              Grupo <%= equipo.grupo.nombre %> ·
              <%= equipo.puntos %> pts ·
              DG <%= equipo.diferencia_de_goles >= 0 ? '+' : '' %><%= equipo.diferencia_de_goles %> ·
              GF <%= equipo.goles_favor %>
            </small>
          </div>

          <% if es_mejor_tercero %>
            <span class="qualified-badge qualified-badge-third">Mejor 3°</span>
          <% else %>
            <span class="qualified-badge qualified-badge-direct">Directo</span>
          <% end %>
        </div>
      <% end %>
    </div>

    <h3 class="clasificados-section-title">Tabla de terceros</h3>

    <% if @terceros_ordenados.any? %>
      <div class="thirds-table-wrapper">
        <table class="group-table" style="table-layout: fixed; width: 100%;">
          <colgroup>
            <col style="width: 36px;">
            <col>
            <col style="width: 56px;">
            <col style="width: 46px;">
            <col style="width: 46px;">
            <col style="width: 46px;">
            <col style="width: 90px;">
          </colgroup>
          <thead>
            <tr>
              <th class="col-stat">#</th>
              <th class="col-team">Equipo</th>
              <th class="col-stat">Grupo</th>
              <th class="col-stat">Pts</th>
              <th class="col-stat">DG</th>
              <th class="col-stat">GF</th>
              <th class="col-stat">Estado</th>
            </tr>
          </thead>
          <tbody>
            <% @terceros_ordenados.each_with_index do |equipo, index| %>
              <tr class="<%= index < 8 ? 'clasificado' : 'tercero-eliminado' %>">
                <td class="col-stat"><%= index + 1 %></td>
                <td class="col-team"><%= equipo.nombre %></td>
                <td class="col-stat"><%= equipo.grupo.nombre %></td>
                <td class="col-stat col-pts"><%= equipo.puntos %></td>
                <td class="col-stat"><%= equipo.diferencia_de_goles %></td>
                <td class="col-stat"><%= equipo.goles_favor %></td>
                <td class="col-stat">
                  <% if index < 8 %>
                    <span class="third-status third-status-in">Clasifica</span>
                  <% else %>
                    <span class="third-status third-status-out">Fuera</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state">
        <p class="empty-state-title">No hay terceros disponibles</p>
        <p class="empty-state-desc">Los terceros lugares aparecerán cuando los grupos tengan suficientes equipos.</p>
      </div>
    <% end %>
  <% end %>

<% else %>
  <!-- ========== ELIMINACIÓN DIRECTA ========== -->
  <div class="section-actions">

    <div class="section-actions-right">
      <% if @torneo.partidos_eliminacion.any? %>
        <span class="stat-pill">Bracket generado</span>
      <% else %>
        <%= button_to "Generar bracket",
              generar_bracket_torneo_path(@torneo),
              method: :post,
              class: "btn-green btn-sm",
              form: { data: { turbo: false } } %>
      <% end %>
    </div>
  </div>

  <% if @torneo.clasificados_eliminatoria.count < 32 %>
    <div class="coming-soon-wrapper">
      <div class="coming-soon-icon">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#C8C8C8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <h3 class="coming-soon-title">Clasificados incompletos</h3>
      <p class="coming-soon-desc">
        Para generar el bracket se necesitan 32 equipos clasificados.
      </p>
      <%= link_to "Ver Clasificados", torneo_path(@torneo, seccion: "clasificados"), class: "btn-stroke" %>
    </div>
  <% elsif @torneo.partidos_eliminacion.empty? %>
    <div class="coming-soon-wrapper">
      <div class="coming-soon-icon">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#C8C8C8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 21h8M12 17v4M6.5 3h11a.5.5 0 0 1 .5.5v3a6 6 0 0 1-12 0v-3a.5.5 0 0 1 .5-.5z"/>
        </svg>
      </div>
    </div>
  <% else %>
    <div class="bracket-stage">
      <div class="bracket-side bracket-left">
        <div class="bracket-round">
          <h4>Dieciseisavos</h4>
          <div class="bracket-round-body">
            <% (1..8).each do |numero| %>
              <%= render "partido_bracket", partido: @partidos_por_numero[numero] %>
            <% end %>
          </div>
        </div>

        <div class="bracket-round">
          <h4>Octavos</h4>
          <div class="bracket-round-body">
            <% (17..20).each do |numero| %>
              <%= render "partido_bracket", partido: @partidos_por_numero[numero] %>
            <% end %>
          </div>
        </div>

        <div class="bracket-round">
          <h4>Cuartos</h4>
          <div class="bracket-round-body">
            <% (25..26).each do |numero| %>
              <%= render "partido_bracket", partido: @partidos_por_numero[numero] %>
            <% end %>
          </div>
        </div>

        <div class="bracket-round">
          <h4>Semifinal</h4>
          <div class="bracket-round-body">
            <%= render "partido_bracket", partido: @partidos_por_numero[29] %>
          </div>
        </div>
      </div>

      <div class="bracket-center">
        <div class="bracket-title-box">
          <span>Eliminación directa</span>
          <strong><%= @torneo.nombre %></strong>
        </div>

        <div class="bracket-trophy">🏆</div>

        <div class="bracket-final-card">
          <h4>Final</h4>
          <%= render "partido_bracket", partido: @partidos_por_numero[32] %>
        </div>

        <div class="bracket-final-card">
          <h4>Tercer lugar</h4>
          <%= render "partido_bracket", partido: @partidos_por_numero[31] %>
        </div>
      </div>

      <div class="bracket-side bracket-right">
        <div class="bracket-round">
          <h4>Semifinal</h4>
          <div class="bracket-round-body">
            <%= render "partido_bracket", partido: @partidos_por_numero[30] %>
          </div>
        </div>

        <div class="bracket-round">
          <h4>Cuartos</h4>
          <div class="bracket-round-body">
            <% (27..28).each do |numero| %>
              <%= render "partido_bracket", partido: @partidos_por_numero[numero] %>
            <% end %>
          </div>
        </div>

        <div class="bracket-round">
          <h4>Octavos</h4>
          <div class="bracket-round-body">
            <% (21..24).each do |numero| %>
              <%= render "partido_bracket", partido: @partidos_por_numero[numero] %>
            <% end %>
          </div>
        </div>

        <div class="bracket-round">
          <h4>Dieciseisavos</h4>
          <div class="bracket-round-body">
            <% (9..16).each do |numero| %>
              <%= render "partido_bracket", partido: @partidos_por_numero[numero] %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <script>
      function abrirModalEliminacion(id) {
        const modal = document.getElementById("modal-eliminacion-" + id);
        modal.style.display = "flex";

        actualizarPenalesEliminacion(id);

        requestAnimationFrame(() => {
          modal.classList.add("visible");
        });
      }

      function cerrarModalEliminacion(id) {
        const modal = document.getElementById("modal-eliminacion-" + id);
        modal.classList.remove("visible");

        setTimeout(() => {
          modal.style.display = "none";
        }, 200);
      }

      function cerrarModalEliminacionSiAfuera(event, id) {
        if (event.target === document.getElementById("modal-eliminacion-" + id)) {
          cerrarModalEliminacion(id);
        }
      }

      function actualizarPenalesEliminacion(id) {
        const gl = document.getElementById("elim_" + id + "_gl");
        const gv = document.getElementById("elim_" + id + "_gv");
        const check = document.getElementById("elim_" + id + "_penales_check");
        const box = document.getElementById("elim_" + id + "_penales_box");

        if (!gl || !gv || !check || !box) return;

        const hayMarcador = gl.value !== "" && gv.value !== "";
        const empate = hayMarcador && parseInt(gl.value) === parseInt(gv.value);

        check.disabled = !empate;

        if (!empate) {
          check.checked = false;
          box.style.display = "none";
        } else if (check.checked) {
          box.style.display = "";
        }
      }

      function togglePenalesEliminacion(id) {
        const check = document.getElementById("elim_" + id + "_penales_check");
        const box = document.getElementById("elim_" + id + "_penales_box");

        if (!check || !box) return;

        box.style.display = check.checked ? "" : "none";
      }
    </script>
  <% end %>
<% end %>
