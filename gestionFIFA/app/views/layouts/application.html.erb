<!DOCTYPE html>
<html lang="es">
  <head>
    <title>Sistema Gestión Mundial 2026</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Sistema de gestión para el Mundial FIFA 2026 - México, Estados Unidos y Canadá">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="page-wrapper">
      <header class="site-header">
        <h1 class="site-title">Sistema Gestión Mundial 2026</h1>
        <nav class="app-nav">
          <%= link_to "Equipos", equipos_path, class: "nav-tab #{controller_name == 'equipos' ? 'active' : ''}" %>
          <%= link_to "Grupos", grupos_path, class: "nav-tab #{controller_name == 'grupos' ? 'active' : ''}" %>
          <%= link_to "Torneo", torneo_path, class: "nav-tab #{controller_name == 'torneo' ? 'active' : ''}" %>
        </nav>
      </header>

      <% if flash[:notice] %>
        <div class="flash-notice"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash-alert"><%= flash[:alert] %></div>
      <% end %>

      <div class="app-container">
        <div class="view-content">
          <%= yield %>
        </div>
      </div>
    </div>

    <script>
      // Ocultar mensajes flash automáticamente después de 5 segundos
      function descartarFlashes() {
        const flashes = document.querySelectorAll(".flash-notice, .flash-alert");
        flashes.forEach(flash => {
          setTimeout(() => {
            flash.style.opacity = "0";
            flash.style.transition = "opacity 0.5s ease";
            setTimeout(() => flash.remove(), 500);
          }, 5000);
        });
      }
      document.addEventListener("DOMContentLoaded", descartarFlashes);
      document.addEventListener("turbo:load", descartarFlashes);
    </script>
  </body>
</html>
